<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- RECEIVE_BOOT_COMPLETED removed — triggers Play Protect block on sideloaded APKs.
         WorkManager handles task persistence across reboots without this permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- SMS permissions requested at runtime when user enables M-Pesa auto-capture.
         NOT declared in manifest to avoid Google Play Protect fraud protection block
         on sideloaded APKs. See: https://developers.google.com/android/play-protect/warning-dev-guidance -->

    <!-- Bluetooth for peer model transfer -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />

    <!-- WiFi Direct for fast peer model transfer -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <!-- Camera for receipt scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Audio recording feature — optional (app also works for receipt scanning, manual entry) -->
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:name=".MsaidiziApp"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Msaidizi"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        tools:targetApi="34">

        <!-- SafeStartActivity (LAUNCHER — crash-safe wrapper for BootstrapActivity) -->
        <activity
            android:name=".SafeStartActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Msaidizi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Bootstrap Onboarding (no longer launcher — launched by SafeStartActivity) -->
        <activity
            android:name=".onboarding.bootstrap.BootstrapActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main Activity (post-onboarding) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait" />

        <!-- Foreground service for voice recording -->
        <service
            android:name=".voice.VoiceForegroundService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!-- Boot receiver removed — triggers Play Protect block on sideloaded APKs.
             WorkManager handles task persistence across reboots automatically. -->

        <!-- SMS receiver removed — triggers Play Protect block on sideloaded APKs.
             M-Pesa integration uses statement import instead of SMS capture. -->

        <!-- WorkManager + other auto-initializers -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- Remove WorkManager auto-init (we initialize manually in MsaidiziApp) -->
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- CRASH FIX: Remove EmojiCompat auto-init (not needed at startup) -->
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- CRASH FIX: Remove ProcessLifecycleInitializer auto-init -->
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
            <!-- CRASH FIX: Remove ProfileInstallerInitializer auto-init -->
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Onboarding -->
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- FileProvider for sharing model files via Bluetooth -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Receipt Scan Activity -->
        <activity
            android:name=".scanner.ReceiptScanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Msaidizi" />

        <!-- SMS receiver fully removed — even disabled receivers trigger Play Protect.
             M-Pesa integration uses statement import instead of SMS capture. -->

        <!-- CRASH FIX: Disable Sentry auto-initialization ContentProviders.
             Sentry's SentryInitProvider and SentryPerformanceProvider run BEFORE
             any Activity. If they crash (empty DSN, class loading issue), the
             entire app dies before our safety wrappers can catch it.
             We initialize Sentry manually in MsaidiziApp.initializeApp(). -->
        <provider
            android:name="io.sentry.android.core.SentryInitProvider"
            android:authorities="${applicationId}.SentryInitProvider"
            tools:node="remove" />
        <provider
            android:name="io.sentry.android.core.SentryPerformanceProvider"
            android:authorities="${applicationId}.SentryPerformanceProvider"
            tools:node="remove" />

        <!-- CRASH FIX: Disable ML Kit auto-initialization.
             MlKitInitProvider runs before any Activity. If ML Kit models are
             missing or corrupted, it crashes the app.
             We initialize ML Kit manually when needed (receipt scanning). -->
        <provider
            android:name="com.google.mlkit.common.internal.MlKitInitProvider"
            android:authorities="${applicationId}.mlkitinitprovider"
            tools:node="remove" />

    </application>
</manifest>
