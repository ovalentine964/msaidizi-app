<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_header"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_language"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/language_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="24dp" />

        <!-- Voice Speed -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_voice_speed"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/voice_speed_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0.5"
            android:valueTo="2.0"
            android:stepSize="0.1"
            android:layout_marginBottom="24dp" />

        <!-- Business Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_business_name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/business_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_business_name_hint"
            android:inputType="text"
            android:minHeight="48dp"
            android:padding="12dp"
            android:background="@drawable/bg_input"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Business Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_business_type"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/business_type_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="24dp" />

        <!-- Auto Sync -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/auto_sync_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_auto_sync"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- WiFi Only -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/wifi_only_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_wifi_only"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Sync Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sync_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_sync_now"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/sync_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

        <!-- Model Management -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/models_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_models"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- WhatsApp Connection (Optional)                         -->
        <!-- ══════════════════════════════════════════════════════ -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WhatsApp (Si Lazima)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/whatsapp_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Haujaunganisha WhatsApp bado."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/whatsapp_connect_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 Unganisha WhatsApp"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unganisha WhatsApp ili kupata ripoti kupitia WhatsApp. Si lazima — SMS inafanya kazi pia."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>
</ScrollView>
