<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/badgeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/badge_locked_stroke">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Main content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Badge emoji -->
            <TextView
                android:id="@+id/badgeEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="36sp"
                tools:text="🏪" />

            <!-- Badge name -->
            <TextView
                android:id="@+id/badgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textStyle="bold"
                tools:text="Biashara Ndogo" />

            <!-- Badge description -->
            <TextView
                android:id="@+id/badgeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Rekodi mauzo yako ya kwanza" />

        </LinearLayout>

        <!-- Lock icon overlay (for locked badges) -->
        <ImageView
            android:id="@+id/badgeLockIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:contentDescription="@string/badge_locked"
            android:src="@drawable/ic_lock"
            android:visibility="gone"
            app:tint="@color/badge_locked_icon" />

        <!-- Earned indicator (checkmark) -->
        <ImageView
            android:id="@+id/badgeEarnedIndicator"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:contentDescription="@string/badge_earned"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone"
            app:tint="@color/badge_earned_indicator" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
