<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_naming_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unataka kuniita nani?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_naming_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chagua jina au andika lako"
        android:textSize="14sp"
        android:gravity="center"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="16dp" />

    <!-- Suggested name chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:paddingBottom="16dp" />

    <!-- Custom name input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Au andika jina lako..."
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:paddingBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_agent_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:maxLength="30" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_use_default"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Msaidizi"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chagua ✓"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
