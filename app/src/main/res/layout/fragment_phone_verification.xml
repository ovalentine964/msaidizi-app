<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".onboarding.PhoneVerificationFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Msaidizi Avatar -->
        <ImageView
            android:id="@+id/imageview_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Msaidizi avatar" />

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 1: Phone Input                                  -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_phone_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/textView_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                android:gravity="center"
                android:text="Sasa ninahitaji namba yako ya simu ili nikutumie ripoti na ujumbe muhimu.\n\nNamba yako ya simu ni ipi?" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:hint="Namba ya simu"
                app:errorEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editText_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:imeOptions="actionDone"
                    android:maxLength="15"
                    android:textSize="20sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_submit_phone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Endelea →"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 2: Channel Selection                            -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_channel_select"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/textView_channel_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                tools:text="Namba yako ni +254 712 345 678\n\nNakutumia nambari ya uthibitisho. Ungependa kupitia wapi?" />

            <TextView
                android:id="@+id/textView_formatted_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="+254 712 345 678" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="14sp"
                android:gravity="center"
                android:text="Nakutumia nambari ya uthibitisho. Ungependa kupitia wapi?" />

            <!-- SMS Button (Primary — highlighted) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_sms"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:text="📱 Tuma kwa SMS"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/sym_action_chat"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="#666666"
                android:text="Inafanya kwa simu zote. Bure kabisa." />

            <!-- Divider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:textSize="14sp"
                android:textColor="#999999"
                android:text="—— au ——" />

            <!-- WhatsApp Button (Secondary) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_whatsapp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="💬 Tuma kwa WhatsApp"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:strokeColor="#25D366"
                app:icon="@android:drawable/sym_action_chat"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:rippleColor="#25D366" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="#666666"
                android:text="Inahitaji WhatsApp imewashwa." />

            <!-- Skip Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_skip_channel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Ruka — nitaweka baadaye" />

            <!-- Edit Phone -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_edit_phone"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="📝 Badilisha namba" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 3: SMS Sending                                  -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_sms_sending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Sending SMS" />

            <TextView
                android:id="@+id/textView_sms_sending_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:gravity="center"
                android:text="Nakutumia SMS ya uthibitisho..." />

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:indeterminate="true" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 4: SMS Code Input (Manual Entry)                -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_sms_code_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/textView_code_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Nambari ya uthibitisho imetumwa!\n\nWeka nambari ya tarakimu 6 uliyopokea kwa SMS:" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout_code"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:hint="000000"
                app:errorEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editText_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:maxLength="6"
                    android:textSize="28sp"
                    android:gravity="center"
                    android:letterSpacing="0.5" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_verify_code"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Thibitisha →"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

            <!-- Resend SMS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_resend_sms"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tuma tena SMS" />

            <!-- Switch to WhatsApp -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_switch_whatsapp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="💬 Badilisha kuwa WhatsApp" />

            <!-- Skip -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_skip_sms"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ruka uthibitisho" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 5: SMS Verifying                                -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_sms_verifying"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                style="@style/Widget.AppCompat.ProgressBar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:text="Inathibitisha nambari..." />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 6: WhatsApp Sending                             -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_whatsapp_sending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="WhatsApp" />

            <TextView
                android:id="@+id/textView_whatsapp_sending_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:text="Nakutumia ujumbe wa WhatsApp sasa..." />

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:indeterminate="true" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 7: WhatsApp Waiting                             -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_whatsapp_waiting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="WhatsApp" />

            <TextView
                android:id="@+id/textView_whatsapp_waiting_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:gravity="center"
                android:text="Ujumbe umetumwa!\nAngalia WhatsApp yako." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_whatsapp_receipt_confirmed"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="✅ Nimepokea!"
                android:textSize="18sp"
                app:cornerRadius="8dp" />

            <!-- Switch to SMS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_switch_sms"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📱 Badilisha kuwa SMS" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_skip_whatsapp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ruka" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 8: Verified                                     -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_verified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Success" />

            <TextView
                android:id="@+id/textView_verified_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="24sp"
                android:textStyle="bold"
                android:text="🎉 Umefanikiwa!" />

            <TextView
                android:id="@+id/textView_verified_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/textView_verified_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_continue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Endelea →"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- PHASE 9: Error                                        -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/textView_error_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:gravity="center"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView_error_guidance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="14sp"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_retry"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="🔄 Jaribu Tena"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

            <!-- Switch channel on error -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_switch_channel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_skip_error"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ruka hatua hii" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
