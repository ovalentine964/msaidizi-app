<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="LinearLayout"
    tools:orientation="vertical">

    <!-- Current level header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/levelEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="40sp"
            tools:text="📚" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/levelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textStyle="bold"
                tools:text="Mwanafunzi" />

            <TextView
                android:id="@+id/levelXpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="45 / 100 XP" />

        </LinearLayout>

        <!-- Progress percentage -->
        <TextView
            android:id="@+id/levelProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_percentile_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/primary"
            tools:text="45%" />

    </LinearLayout>

    <!-- XP Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/levelProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/surface_variant"
        app:trackCornerRadius="8dp"
        app:trackThickness="10dp" />

    <!-- Current level perks -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/current_perks"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <LinearLayout
        android:id="@+id/levelPerksContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical" />

    <!-- Next level preview -->
    <LinearLayout
        android:id="@+id/nextLevelSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/nextLevelTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textStyle="bold"
            tools:text="🚀 Level ijayo: Mfanyabiashara" />

        <LinearLayout
            android:id="@+id/nextLevelPerksContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/pointsToNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/primary"
            android:textStyle="bold"
            tools:text="Pointi 55 zaidi" />

    </LinearLayout>

    <!-- Legend celebration (max level) -->
    <TextView
        android:id="@+id/legendCelebration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="@color/level_legend"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="⭐ Umeifikia Legend! Wewe ni mfano bora!" />

</merge>
