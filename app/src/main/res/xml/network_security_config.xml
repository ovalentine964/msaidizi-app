<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration — Msaidizi
  Enforces TLS 1.3 minimum, certificate pinning for API endpoints.
-->
<network-security-config>
    <!-- Disable cleartext (plaintext HTTP) globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <!-- Enforce TLS 1.2+ at Android level (TLS 1.3 preferred via OkHttp) -->
    </base-config>

    <!-- Pin certificates for production API -->
    <domain-config>
        <domain includeSubdomains="true">api.angavu.io</domain>
        <pin-set expiration="2027-01-01">
            <!-- Backup pins — rotate annually -->
            <pin digest="SHA-256">PLACEHOLDER_PIN_1_BASE64=</pin>
            <pin digest="SHA-256">PLACEHOLDER_PIN_2_BASE64=</pin>
        </pin-set>
    </domain-config>

    <!-- Debug overrides (allow user-installed certs for dev proxying) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
